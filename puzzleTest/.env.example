# OpenAI API key — required to parse the natural-language grid description
OPENAI_API_KEY=your-api-key-here

# OpenAI model for grid parsing (gpt-4o-mini is fast and cheap)
OPENAI_MODEL=gpt-4o-mini

# BotCaptcha server URL
BOTCAPTCHA_URL=http://127.0.0.1:3000

# Test configuration
NUM_TESTS=10
VERBOSE=true
